generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

enum WebUserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum TodoStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TodoPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model WebUser {
  id                String    @id @default(uuid())
  email             String    @unique
  displayName       String
  role              WebUserRole @default(USER)
  status            UserStatus @default(ACTIVE)
  googleId          String?   @unique
  emailVerifiedAt   DateTime?
  theme             String?
  colorMode         String?
  storageUsedBytes  BigInt    @default(0)
  storageQuotaBytes BigInt    @default(-1)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  auditLogs         AuditLog[]
  todos             Todo[]
  @@map("web_users")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entityType String?
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())

  user       WebUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model AppSettings {
  id        String  @id @default(uuid())
  key       String  @unique
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model MagicLinkToken {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("magic_link_tokens")
}

model Todo {
  id              String        @id @default(uuid())
  userId          String
  title           String
  description     String?
  status          TodoStatus    @default(PENDING)
  priority        TodoPriority  @default(MEDIUM)
  completedAt     DateTime?
  dueDate         DateTime?
  attachmentPath  String?
  attachmentName  String?
  attachmentSize  BigInt?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            WebUser       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("todos")
}
