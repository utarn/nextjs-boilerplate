# Dependencies
node_modules/

# Next.js
.next/
out/
build/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Prisma
# Migrations are tracked (force-added); the rules below keep the lock file and
# migration directories trackable while ignoring stray files Prisma may drop
# at the migrations root. Mirrors the lab-check setup.
prisma/migrations/*
!prisma/migrations/README.md
!prisma/migrations/migration_lock.toml
!prisma/migrations/**/

# Testing
coverage/

# Playwright
playwright/.auth/
playwright/test-results/

# Storage (data directory only, not src/lib/storage/)
/storage/
uploads/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

