# =============================================================================
# Next.js Boilerplate — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# ---- Application ----
NEXT_PUBLIC_APP_NAME="Next.js Boilerplate"
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000

# ---- Database (PostgreSQL) ----
# Required. PostgreSQL connection string.
DATABASE_URL=postgresql://boilerplate:boilerplate123@localhost:5432/boilerplate

# ---- Redis (BullMQ) ----
# Required. Redis connection string for background job processing.
REDIS_URL=redis://localhost:6379

# ---- Encryption ----
# Required. 32+ character secret key for JWT signing and encryption.
# Generate with: openssl rand -hex 32
ENCRYPTION_SECRET=

# ---- SMTP (for magic link emails) ----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_EMAIL=noreply@example.com
SMTP_SENDER_NAME="Next.js Boilerplate"
SMTP_USE_SSL=false
SMTP_INSECURE_SKIP_VERIFY=false

# ---- Admin Bootstrap ----
# On first seed, a user with this email will be created as ADMIN.
ADMIN_EMAIL=
ADMIN_DISPLAY_NAME="Admin User"

# ---- Google OAuth ----
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Storage ----
# Storage adapter type: "local" (default)
STORAGE_TYPE=local
# Local storage path (default: ./storage)
# STORAGE_LOCAL_PATH=./storage

# ---- Default Quotas ----
DEFAULT_MAX_FILES_PER_USER=1000
DEFAULT_MAX_STORAGE_MB_PER_USER=1000
DEFAULT_MAX_TODOS_PER_USER=1000
